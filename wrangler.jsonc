{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ronda-editorial-webapp",
  "main": "src/index.js",
  "compatibility_date": "2026-07-22",
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB"
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "ENVIRONMENT": "production"
  }
}
